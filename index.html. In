  </div>
  <div class="config-row">
    <span class="config-label">Min Edge</span>
    <input type="number" class="config-input" id="cfgEdge" value="0.04" step="0.01" min="0.01" onchange="updateConfig()">
  </div>
  <div class="config-row">
    <span class="config-label">Max Exposure</span>
    <input type="number" class="config-input" id="cfgMaxExp" value="0.20" step="0.05" min="0.05" onchange="updateConfig()">
  </div>
  <div class="config-row">
    <span class="config-label">Max Drawdown</span>
    <span class="config-val">8%</span>
  </div>
  <div class="config-row">
    <span class="config-label">VaR Confidence</span>
    <span class="config-val">95%</span>
  </div>
