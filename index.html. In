<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PREDICT & EXECUTE — Market Bot</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&family=Bebas+Neue&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #080c0f;
    --surface: #0d1318;
    --surface2: #111920;
    --border: #1e2d35;
    --border2: #243540;
    --green: #00e5a0;
    --green-dim: #00b87d;
    --green-glow: rgba(0,229,160,0.12);
    --red: #ff4560;
    --red-dim: #cc3a4d;
    --amber: #ffb830;
    --blue: #38b6ff;
    --text: #c8dce8;
    --text-dim: #5a7a8a;
    --text-bright: #e8f4fc;
    --mono: 'IBM Plex Mono', monospace;
    --display: 'Bebas Neue', sans-serif;
    --sans: 'IBM Plex Sans', sans-serif;
  }
  * { margin:0; padding:0; box-sizing:border-box; }

body {
background: var(–bg);
color: var(–text);
font-family: var(–mono);
min-height: 100vh;
overflow-x: hidden;
}

/* GRID NOISE */
body::before {
content:’’;
position:fixed; inset:0;
background-image:
linear-gradient(rgba(0,229,160,0.02) 1px, transparent 1px),
linear-gradient(90deg, rgba(0,229,160,0.02) 1px, transparent 1px);
background-size: 40px 40px;
pointer-events:none; z-index:0;
}

.scanline {
position:fixed; top:0; left:0; right:0; height:2px;
background: linear-gradient(90deg, transparent, var(–green), transparent);
animation: scanline 4s linear infinite;
z-index:100; opacity:0.4;
}
@keyframes scanline { 0%{top:-2px} 100%{top:100vh} }

/* HEADER */
header {
position:relative; z-index:10;
border-bottom: 1px solid var(–border);
padding: 0 32px;
display:flex; align-items:center; justify-content:space-between;
height:56px;
background: rgba(8,12,15,0.95);
backdrop-filter: blur(8px);
}
.logo {
font-family: var(–display);
font-size: 22px;
letter-spacing: 3px;
color: var(–green);
text-shadow: 0 0 20px rgba(0,229,160,0.5);
}
.logo span { color: var(–text-dim); font-size:11px; font-family:var(–mono); letter-spacing:2px; margin-left:12px; vertical-align:middle; }
.header-status {
display:flex; align-items:center; gap:24px; font-size:11px;
}
.status-dot {
width:7px; height:7px; border-radius:50%;
background: var(–green);
box-shadow: 0 0 8px var(–green);
animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
.status-label { color: var(–text-dim); }
.status-val { color: var(–green); font-weight:500; }

/* MAIN LAYOUT */
.main { position:relative; z-index:1; display:grid; grid-template-columns:260px 1fr 300px; height:calc(100vh - 56px); }

/* LEFT PANEL — Pipeline */
.left-panel {
border-right: 1px solid var(–border);
overflow-y:auto;
padding: 20px 0;
background: var(–surface);
}
.panel-title {
font-size:10px; letter-spacing:3px; color:var(–text-dim);
text-transform:uppercase; padding: 0 20px 16px;
}
.pipeline-step {
padding: 14px 20px;
border-left: 3px solid transparent;
cursor:pointer;
transition: all 0.2s;
position:relative;
}
.pipeline-step:hover { background: var(–surface2); }
.pipeline-step.active { border-left-color: var(–green); background: var(–surface2); }
.pipeline-step.running { border-left-color: var(–amber); }
.pipeline-step.done { border-left-color: var(–green-dim); }
.pipeline-step.error { border-left-color: var(–red); }
.step-header { display:flex; align-items:center; gap:10px; margin-bottom:6px; }
.step-num { font-size:10px; color:var(–text-dim); width:14px; }
.step-name { font-size:13px; font-weight:500; color:var(–text-bright); }
.step-badge {
font-size:8px; padding:2px 6px; border-radius:2px;
letter-spacing:1px; text-transform:uppercase; font-weight:600;
margin-left:auto;
}
.badge-seq { background:rgba(56,182,255,0.15); color:var(–blue); border:1px solid rgba(56,182,255,0.3); }
.badge-mcp { background:rgba(255,184,48,0.15); color:var(–amber); border:1px solid rgba(255,184,48,0.3); }
.badge-domain { background:rgba(0,229,160,0.1); color:var(–green-dim); border:1px solid rgba(0,229,160,0.25); }
.badge-ctx { background:rgba(255,69,96,0.12); color:var(–red); border:1px solid rgba(255,69,96,0.25); }
.badge-iter { background:rgba(200,220,232,0.08); color:var(–text-dim); border:1px solid var(–border2); }
.step-desc { font-size:10px; color:var(–text-dim); line-height:1.6; padding-left:24px; }
.step-progress {
height:2px; background:var(–border); margin:8px 20px 0; border-radius:1px; overflow:hidden;
}
.step-progress-bar { height:100%; background:var(–green); transition:width 0.4s; }

.divider { height:1px; background:var(–border); margin:16px 20px; }

/* CONFIG */
.config-section { padding: 0 20px; }
.config-row { display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; }
.config-label { font-size:10px; color:var(–text-dim); }
.config-val { font-size:11px; color:var(–green); font-weight:500; }
.config-input {
background:var(–surface2); border:1px solid var(–border2);
color:var(–text-bright); font-family:var(–mono); font-size:11px;
padding:4px 8px; width:80px; text-align:right;
border-radius:2px; outline:none;
}
.config-input:focus { border-color:var(–green); }

/* CENTER — Main Content */
.center-panel { overflow-y:auto; padding:24px; display:flex; flex-direction:column; gap:20px; }

/* STATS ROW */
.stats-row { display:grid; grid-template-columns:repeat(5,1fr); gap:12px; }
.stat-card {
background:var(–surface); border:1px solid var(–border);
padding:16px; border-radius:4px; position:relative; overflow:hidden;
}
.stat-card::after {
content:’’; position:absolute; top:0; left:0; right:0; height:1px;
background: linear-gradient(90deg, transparent, var(–green), transparent);
opacity:0;
transition: opacity 0.3s;
}
.stat-card:hover::after { opacity:1; }
.stat-label { font-size:9px; letter-spacing:2px; color:var(–text-dim); text-transform:uppercase; margin-bottom:8px; }
.stat-val { font-family:var(–display); font-size:28px; letter-spacing:1px; }
.stat-val.green { color:var(–green); text-shadow:0 0 16px rgba(0,229,160,0.3); }
.stat-val.red { color:var(–red); }
.stat-val.amber { color:var(–amber); }
.stat-val.blue { color:var(–blue); }
.stat-val.white { color:var(–text-bright); }
.stat-sub { font-size:9px; color:var(–text-dim); margin-top:4px; }

/* P&L CHART */
.chart-card {
background:var(–surface); border:1px solid var(–border);
padding:20px; border-radius:4px;
}
.chart-header { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; }
.chart-title { font-size:10px; letter-spacing:3px; color:var(–text-dim); text-transform:uppercase; }
.chart-meta { display:flex; gap:16px; }
.chart-tag { font-size:10px; color:var(–text-dim); }
.chart-tag span { color:var(–green); }
canvas#pnlChart { width:100%!important; height:160px!important; }

/* MARKETS TABLE */
.table-card {
background:var(–surface); border:1px solid var(–border);
border-radius:4px; overflow:hidden;
}
.table-header {
display:flex; justify-content:space-between; align-items:center;
padding:14px 20px; border-bottom:1px solid var(–border);
}
.table-title { font-size:10px; letter-spacing:3px; color:var(–text-dim); text-transform:uppercase; }
.table-actions { display:flex; gap:8px; }
.btn {
font-family:var(–mono); font-size:10px; letter-spacing:1px;
padding:5px 12px; border:1px solid var(–border2);
background:transparent; color:var(–text); cursor:pointer;
border-radius:2px; transition:all 0.2s; text-transform:uppercase;
}
.btn:hover { border-color:var(–green); color:var(–green); }
.btn.primary { background:rgba(0,229,160,0.1); border-color:var(–green); color:var(–green); }
.btn.primary:hover { background:rgba(0,229,160,0.2); }
.btn.danger { border-color:var(–red); color:var(–red); }

table { width:100%; border-collapse:collapse; }
thead tr { background:var(–surface2); }
th { font-size:9px; letter-spacing:2px; color:var(–text-dim); text-transform:uppercase; padding:10px 14px; text-align:left; font-weight:400; }
td { font-size:11px; padding:10px 14px; border-top:1px solid var(–border); vertical-align:middle; }
tbody tr { transition:background 0.15s; cursor:pointer; }
tbody tr:hover { background:var(–surface2); }
.tag { display:inline-block; font-size:8px; padding:2px 6px; border-radius:2px; letter-spacing:1px; text-transform:uppercase; }
.tag-buy { background:rgba(0,229,160,0.12); color:var(–green); border:1px solid rgba(0,229,160,0.25); }
.tag-sell { background:rgba(255,69,96,0.12); color:var(–red); border:1px solid rgba(255,69,96,0.25); }
.tag-watch { background:rgba(255,184,48,0.1); color:var(–amber); border:1px solid rgba(255,184,48,0.25); }
.tag-block { background:rgba(100,100,100,0.1); color:var(–text-dim); border:1px solid var(–border); }
.edge-bar { height:4px; border-radius:2px; background:var(–border); margin-top:4px; }
.edge-fill { height:100%; border-radius:2px; background:var(–green); transition:width 0.5s; }
.edge-fill.red { background:var(–red); }

/* RISK SECTION */
.two-col { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
.formula-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.formula-card {
background:var(–surface2); border:1px solid var(–border);
padding:12px; border-radius:3px;
}
.formula-cat { font-size:8px; letter-spacing:2px; color:var(–text-dim); text-transform:uppercase; margin-bottom:8px; }
.formula-expr {
font-size:13px; color:var(–green); font-weight:500; margin-bottom:4px; letter-spacing:0.5px;
}
.formula-desc { font-size:9px; color:var(–text-dim); line-height:1.5; }

/* RISK GAUGES */
.gauge-row { display:flex; flex-direction:column; gap:10px; }
.gauge-item {}
.gauge-header { display:flex; justify-content:space-between; margin-bottom:5px; }
.gauge-name { font-size:10px; color:var(–text-dim); }
.gauge-val { font-size:10px; font-weight:500; }
.gauge-track { height:6px; background:var(–border); border-radius:3px; overflow:hidden; }
.gauge-fill { height:100%; border-radius:3px; transition:width 0.8s ease; }
.gauge-fill.green { background: linear-gradient(90deg, var(–green-dim), var(–green)); }
.gauge-fill.amber { background: linear-gradient(90deg, #cc8800, var(–amber)); }
.gauge-fill.red { background: linear-gradient(90deg, var(–red-dim), var(–red)); }

/* TRADE LOG */
.log-entry {
display:flex; gap:12px; align-items:flex-start;
padding:10px 14px; border-top:1px solid var(–border);
font-size:10px;
}
.log-time { color:var(–text-dim); white-space:nowrap; }
.log-msg { color:var(–text); flex:1; }
.log-msg.success { color:var(–green); }
.log-msg.warn { color:var(–amber); }
.log-msg.error { color:var(–red); }
.log-msg.info { color:var(–blue); }

/* RIGHT PANEL */
.right-panel {
border-left:1px solid var(–border);
overflow-y:auto;
background: var(–surface);
}
.right-section { padding:20px; border-bottom:1px solid var(–border); }
.right-title { font-size:9px; letter-spacing:3px; color:var(–text-dim); text-transform:uppercase; margin-bottom:14px; }

/* KELLY CALCULATOR */
.kelly-display {
background:var(–surface2); border:1px solid var(–border2);
padding:16px; border-radius:3px; margin-bottom:12px;
}
.kelly-formula { font-size:11px; color:var(–green); margin-bottom:4px; }
.kelly-result {
font-family:var(–display); font-size:36px;
color:var(–green); letter-spacing:1px;
text-shadow:0 0 20px rgba(0,229,160,0.4);
}
.kelly-unit { font-size:10px; color:var(–text-dim); margin-top:4px; }

.input-row { margin-bottom:10px; }
.input-label { font-size:9px; color:var(–text-dim); letter-spacing:1px; text-transform:uppercase; margin-bottom:4px; }
.input-field {
width:100%; background:var(–surface2); border:1px solid var(–border2);
color:var(–text-bright); font-family:var(–mono); font-size:12px;
padding:7px 10px; border-radius:2px; outline:none;
}
.input-field:focus { border-color:var(–green); box-shadow:0 0 0 1px rgba(0,229,160,0.1); }

.risk-checks { display:flex; flex-direction:column; gap:6px; }
.risk-check { display:flex; gap:8px; align-items:center; font-size:10px; }
.check-icon { width:16px; height:16px; border-radius:2px; display:flex; align-items:center; justify-content:center; font-size:9px; flex-shrink:0; }
.check-pass { background:rgba(0,229,160,0.15); color:var(–green); border:1px solid rgba(0,229,160,0.3); }
.check-fail { background:rgba(255,69,96,0.15); color:var(–red); border:1px solid rgba(255,69,96,0.3); }
.check-warn { background:rgba(255,184,48,0.15); color:var(–amber); border:1px solid rgba(255,184,48,0.3); }
.check-label { color:var(–text-dim); flex:1; }
.check-val { color:var(–text-bright); font-size:9px; }

/* AGENT STATUS */
.agent-list { display:flex; flex-direction:column; gap:6px; }
.agent-row { display:flex; gap:8px; align-items:center; padding:6px 8px; background:var(–surface2); border-radius:2px; border:1px solid var(–border); }
.agent-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
.agent-dot.active { background:var(–green); box-shadow:0 0 6px var(–green); animation:pulse 1.5s infinite; }
.agent-dot.idle { background:var(–text-dim); }
.agent-dot.working { background:var(–amber); box-shadow:0 0 6px var(–amber); animation:pulse 1s infinite; }
.agent-name { font-size:10px; color:var(–text); flex:1; }
.agent-status { font-size:9px; color:var(–text-dim); }

/* SCROLLBAR */
::-webkit-scrollbar { width:4px; }
::-webkit-scrollbar-track { background:transparent; }
::-webkit-scrollbar-thumb { background:var(–border2); border-radius:2px; }

/* ANIMATIONS */
@keyframes fadeIn { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:translateY(0)} }
.fade-in { animation: fadeIn 0.4s ease forwards; }
.fade-in-1 { animation-delay:0.1s; opacity:0; }
.fade-in-2 { animation-delay:0.2s; opacity:0; }
.fade-in-3 { animation-delay:0.3s; opacity:0; }
.fade-in-4 { animation-delay:0.4s; opacity:0; }
.fade-in-5 { animation-delay:0.5s; opacity:0; }

.flash { animation:flashGreen 0.6s ease; }
@keyframes flashGreen { 0%{background:rgba(0,229,160,0.08)} 100%{background:transparent} }

.bot-running .pipeline-step.active .step-progress-bar { animation:progressAnim 2s ease-in-out; }
@keyframes progressAnim { 0%{width:0%} 60%{width:85%} 100%{width:100%} }

/* MODAL */
.modal-overlay {
position:fixed; inset:0; background:rgba(0,0,0,0.7);
z-index:200; display:flex; align-items:center; justify-content:center;
opacity:0; pointer-events:none; transition:opacity 0.2s;
backdrop-filter:blur(4px);
}
.modal-overlay.open { opacity:1; pointer-events:all; }
.modal {
background:var(–surface); border:1px solid var(–border2);
width:500px; border-radius:4px; overflow:hidden;
transform:translateY(10px); transition:transform 0.2s;
}
.modal-overlay.open .modal { transform:translateY(0); }
.modal-header { padding:16px 20px; border-bottom:1px solid var(–border); display:flex; justify-content:space-between; align-items:center; }
.modal-title { font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(–text-bright); }
.modal-close { background:none; border:none; color:var(–text-dim); cursor:pointer; font-size:16px; line-height:1; }
.modal-body { padding:20px; }
.modal-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; margin-bottom:12px; }
.modal-footer { padding:14px 20px; border-top:1px solid var(–border); display:flex; gap:8px; justify-content:flex-end; }
</style>

</head>
