// ══════════════════════════════════════════
// BACKTEST ENGINE
// ══════════════════════════════════════════
function runBacktest() {
  const capital   = parseFloat(document.getElementById('btCapital').value) || 10000;
  const winRate   = parseFloat(document.getElementById('btWinRate').value) / 100 || 0.58;
  const numTrades = parseInt(document.getElementById('btTrades').value) || 100;
  const strategy  = document.getElementById('btStrategy').value;

  let equity = [capital];
  let bankroll = capital;
  let maxEquity = capital;
  let maxDD = 0;
  const returns = [];
  const logEl = document.getElementById('btLog');
  logEl.innerHTML = '';

  for (let i = 0; i < numTrades; i++) {
    let fraction;
    if (strategy === 'Kelly Full')    fraction = 0.08 + Math.random() * 0.04;
    else if (strategy === 'Quarter Kelly') fraction = 0.02 + Math.random() * 0.02;
    else if (strategy === 'Half Kelly')   fraction = 0.04 + Math.random() * 0.03;
    else if (strategy === 'Fixed 2%')    fraction = 0.02;
    else fraction = 0.05;

    const stake = bankroll * fraction;
    const win   = Math.random() < winRate;
    const pnl   = win ? stake * (1.5 + Math.random()) : -stake;
    bankroll   += pnl;
    if (bankroll < 0) bankroll = 0;
    equity.push(bankroll);
    returns.push(pnl / (bankroll - pnl || 1));
    maxEquity = Math.max(maxEquity, bankroll);
    const dd = (maxEquity - bankroll) / maxEquity;
    maxDD = Math.max(maxDD, dd);

    if (i < 15 || i === numTrades - 1) {
      const type = win ? 'ok' : 'err';
      addLog('btLog', type, `Trade ${i+1}: ${win?'WIN':'LOSS'} $${Math.abs(pnl).toFixed(2)} | Equity: $${bankroll.toFixed(2)}`);
    } else if (i === 15) {
      addLog('btLog', 'info', '... (truncated) ...');
    }
  }

  const totalReturn = ((bankroll - capital) / capital * 100);
  const avgReturn   = returns.reduce((a, b) => a + b, 0) / returns.length;
  const stdReturn   = Math.sqrt(returns.reduce((a, b) => a + Math.pow(b - avgReturn, 2), 0) / returns.length);
  const sharpe      = stdReturn > 0 ? ((avgReturn / stdReturn) * Math.sqrt(252)).toFixed(2) : '0.00';

  document.getElementById('btFinal').textContent  = '$' + bankroll.toFixed(2);
  document.getElementById('btReturn').textContent = (totalReturn >= 0 ? '+' : '') + totalReturn.toFixed(1) + '%';
  document.getElementById('btReturn').className   = totalReturn >= 0 ? 'up' : 'down';
  document.getElementById('btDD').textContent     = '-' + (maxDD * 100).toFixed(1) + '%';
  document.getElementById('btSharpe').textContent = sharpe;

  drawBacktestChart(equity);
}

