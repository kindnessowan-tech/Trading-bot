  ['ok',   'Daily P&L: +$247.83 | Sharpe: 2.14'],
];

function addLog(id, type, msg) {
  const el = document.getElementById(id);
  if (!el) return;
  const now = new Date().toTimeString().slice(0, 8);
  const div = document.createElement('div');
  div.className = 'log-line';
  div.innerHTML = `<span class="log-ts">${now}</span><span class="log-${type}">${msg}</span>`;
  el.appendChild(div);
  el.scrollTop = el.scrollHeight;
}

function buildLog() {
  LOG_MESSAGES.forEach(([type, msg], i) => {
    setTimeout(() => addLog('sysLog', type, msg), i * 300);
  });
}

// ══════════════════════════════════════════
// TICKER
// ══════════════════════════════════════════
function buildTicker() {
  const items = MARKETS.map(m => {
    const ev = calcEV(m.prob, m.mktProb);
    const sign = ev > 0 ? '▲' : '▼';
    const color = ev > 0 ? 'var(--green)' : 'var(--red)';
    return `<span style="margin:0 24px">${m.name} <span style="color:${color}">${sign}${(Math.abs(ev)*100).toFixed(1)}% EV</span></span>`;
  }).join('');
  document.getElementById('ticker').innerHTML = items + items;
}

// ══════════════════════════════════════════
// CORRELATION MATRIX
// ══════════════════════════════════════════
function buildCorrMatrix() {
  const assets = ['FED', 'BTC', 'OIL', 'ETH', 'GOLD'];
  const corr = [
    [1.00,  0.12, -0.08,  0.15,  0.22],
    [0.12,  1.00,  0.34,  0.87, -0.11],
    [-0.08, 0.34,  1.00,  0.28,  0.41],
    [0.15,  0.87,  0.28,  1.00, -0.09],
    [0.22, -0.11,  0.41, -0.09,  1.00],
  ];

  let html = '<table style="border-collapse:collapse">';
  html += '<tr><td style="padding:4px 8px"></td>' +
    assets.map(a => `<td style="padding:4px 8px;color:var(--cyan-dim);font-size:0.65rem;letter-spacing:1px">${a}</td>`).join('') + '</tr>';
  corr.forEach((row, i) => {
    html += `<tr><td style="padding:4px 8px;color:var(--cyan-dim);font-size:0.65rem">${assets[i]}</td>`;
    row.forEach(v => {
      const abs = Math.abs(v);
      const r = v < 0 ? 255 : 0, g = v > 0 ? 255 : 0;
      const alpha = (abs * 0.6).toFixed(2);
      html += `<td style="padding:4px 10px;background:rgba(${r},${g},136,${alpha});
        color:var(--text);text-align:center;font-size:0.75rem;
        font-family:'DM Mono',monospace">${v.toFixed(2)}</td>`;
    });
    html += '</tr>';
  });
  html += '</table>';
  document.getElementById('corrMatrix').innerHTML = html;
}

// ══════════════════════════════════════════
// INIT
// ══════════════════════════════════════════
window.addEventListener('load', () => {
  renderDashboard();
  buildLog();
  buildTicker();
  runScan();
  calcKelly();
  updateRisk();
  buildCorrMatrix();
