// ══════════════════════════════════════════
// KELLY CALCULATOR
// ══════════════════════════════════════════
let positions = [];

function calcKelly() {
  const p     = parseFloat(document.getElementById('kWinProb').value) / 100;
  const odds  = parseFloat(document.getElementById('kOdds').value);
  const bank  = parseFloat(document.getElementById('kBankroll').value);
  const frac  = parseFloat(document.getElementById('kFraction').value);

  if (!p || !odds || !bank || odds < 1) return;

  const b = odds - 1;
  const q = 1 - p;
  const kellyFull = (b * p - q) / b;
  const kellyAdjusted = Math.max(0, kellyFull) * frac;
  const betAmt = kellyAdjusted * bank;
  const ev = (p * b) - q;
  const varAmt = betAmt * 1.645 * 0.3;
  const brier = Math.pow(p - 0.6, 2).toFixed(4);

  document.getElementById('kellyAmt').textContent  = '$' + betAmt.toFixed(2);
  document.getElementById('kellyPct').textContent  = (kellyAdjusted * 100).toFixed(2) + '% of bankroll';
  document.getElementById('kellyEV').innerHTML     = `<span class="${ev>0?'up':'down'}">EV: ${ev>0?'+':''}${(ev*100).toFixed(2)}%</span>`;
  document.getElementById('evDisplay').textContent  = (ev>0?'+':'') + (ev*100).toFixed(2) + '%';
  document.getElementById('evDisplay').className    = 'stat-val ' + (ev>0?'up':'down');
  document.getElementById('varDisplay').textContent = '-$' + varAmt.toFixed(2);
  document.getElementById('brierDisplay').textContent = brier;
}

function placeTrade() {
  const p    = parseFloat(document.getElementById('kWinProb').value) / 100;
  const odds = parseFloat(document.getElementById('kOdds').value);
  const bank = parseFloat(document.getElementById('kBankroll').value);
  const frac = parseFloat(document.getElementById('kFraction').value);
  const b    = odds - 1;
  const kelly = Math.max(0, (b * p - (1-p)) / b) * frac;
  const amt  = (kelly * bank).toFixed(2);
  const ev   = ((p * b) - (1 - p) * 100).toFixed(2);
  const market = 'Custom Market';

  positions.push({ market, stake: amt, prob: p, ev: ((p*b-(1-p))*100).toFixed(1) });
  renderPositions();
  addLog('sysLog', 'ok', `TRADE: $${amt} @ ${(p*100).toFixed(0)}% prob | EV ${ev}%`);
}

function renderPositions() {
  const tbody = document.getElementById('positionsTable');
