<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>TRADING BOT — Prediction Market Engine</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;700;900&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #020408;
      --bg2:       #060d14;
      --bg3:       #0a1520;
      --border:    #0f2a3f;
      --border2:   #1a3f5c;
      --cyan:      #00e5ff;
      --cyan-dim:  #0097aa;
      --green:     #00ff88;
      --green-dim: #00804a;
      --red:       #ff3860;
      --red-dim:   #7a1530;
      --yellow:    #ffd600;
      --yellow-dim:#7a6500;
      --text:      #c8dde8;
      --text-dim:  #4a6a7a;
      --text-faint:#1e3040;
      --glow-c:    0 0 12px #00e5ff55;
      --glow-g:    0 0 12px #00ff8855;
      --glow-r:    0 0 12px #ff386055;
    }

    html { font-size: 13px; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Mono', monospace;
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* scanline overlay */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,229,255,0.012) 2px,
        rgba(0,229,255,0.012) 4px
      );
      pointer-events: none;
      z-index: 9999;
    }

    /* grid bg */
    body::after {
      content: '';
      position: fixed; inset: 0;
      background-image:
        linear-gradient(var(--text-faint) 1px, transparent 1px),
        linear-gradient(90deg, var(--text-faint) 1px, transparent 1px);
      background-size: 40px 40px;
      opacity: 0.3;
      pointer-events: none;
      z-index: 0;
    }

    #app { position: relative; z-index: 1; max-width: 1400px; margin: 0 auto; padding: 16px; }

    /* ── HEADER ── */
    header {
      display: flex; align-items: center; justify-content: space-between;
      border-bottom: 1px solid var(--border2);
      padding-bottom: 12px; margin-bottom: 16px;
    }
    .logo {
      font-family: 'Orbitron', monospace;
      font-size: 1.3rem; font-weight: 900;
      color: var(--cyan);
      text-shadow: var(--glow-c);
      letter-spacing: 3px;
    }
    .logo span { color: var(--green); }
    .header-right { display: flex; align-items: center; gap: 16px; }
    .status-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--green);
      box-shadow: var(--glow-g);
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%,100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.8); }
    }
    .clock { font-size: 0.85rem; color: var(--cyan-dim); letter-spacing: 1px; }

    /* ── TABS ── */
    .tabs {
      display: flex; gap: 2px; margin-bottom: 16px;
      border-bottom: 1px solid var(--border);
    }
    .tab {
      padding: 8px 18px; cursor: pointer;
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.85rem; letter-spacing: 1px;
      color: var(--text-dim); border: none;
      background: transparent;
      border-bottom: 2px solid transparent;
      transition: all 0.2s; text-transform: uppercase;
    }
    .tab:hover { color: var(--cyan); }
    .tab.active {
      color: var(--cyan);
      border-bottom-color: var(--cyan);
      text-shadow: var(--glow-c);
    }

    /* ── PANELS ── */
    .panel { display: none; }
    .panel.active { display: block; }

    /* ── GRID LAYOUT ── */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
    .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
    .col-span-2 { grid-column: span 2; }
    .col-span-3 { grid-column: span 3; }

    /* ── CARD ── */
    .card {
      background: var(--bg2);
      border: 1px solid var(--border);
      border-radius: 2px;
      padding: 14px;
    }
    .card:hover { border-color: var(--border2); }
    .card-title {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.7rem; letter-spacing: 2px;
      color: var(--cyan-dim); text-transform: uppercase;
      margin-bottom: 10px;
      display: flex; align-items: center; gap: 8px;
    }
    .card-title::before {
      content: '▸'; color: var(--cyan);
    }

    /* ── STAT BOXES ── */
    .stat-val {
      font-family: 'Orbitron', monospace;
      font-size: 1.6rem; font-weight: 700;
      line-height: 1;
    }
    .stat-label { font-size: 0.7rem; color: var(--text-dim); margin-top: 4px; letter-spacing: 1px; }
    .stat-change { font-size: 0.75rem; margin-top: 6px; }
    .up { color: var(--green); }
    .down { color: var(--red); }
    .neutral { color: var(--yellow); }

    /* ── TABLE ── */
    .data-table { width: 100%; border-collapse: collapse; font-size: 0.8rem; }
    .data-table th {
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.65rem; letter-spacing: 1.5px;
      color: var(--text-dim); text-transform: uppercase;
      padding: 6px 8px; text-align: left;
      border-bottom: 1px solid var(--border);
    }
    .data-table td {
      padding: 7px 8px;
      border-bottom: 1px solid var(--text-faint);
      vertical-align: middle;
    }
    .data-table tr:hover td { background: var(--bg3); }

    /* ── BADGE ── */
    .badge {
      display: inline-block; padding: 2px 8px;
      font-size: 0.65rem; letter-spacing: 1px;
      border-radius: 2px; font-family: 'Share Tech Mono', monospace;
    }
    .badge-green { background: #00ff8820; color: var(--green); border: 1px solid var(--green-dim); }
    .badge-red   { background: #ff386020; color: var(--red);   border: 1px solid var(--red-dim); }
    .badge-yellow{ background: #ffd60020; color: var(--yellow);border: 1px solid var(--yellow-dim); }
    .badge-cyan  { background: #00e5ff15; color: var(--cyan);  border: 1px solid var(--cyan-dim); }

    /* ── PROGRESS BAR ── */
    .prog-bar {
      height: 4px; background: var(--text-faint);
      border-radius: 2px; overflow: hidden; margin-top: 8px;
    }
    .prog-fill {
      height: 100%; border-radius: 2px;
      transition: width 0.6s ease;
    }
    .prog-fill.cyan  { background: var(--cyan); box-shadow: var(--glow-c); }
    .prog-fill.green { background: var(--green); box-shadow: var(--glow-g); }
    .prog-fill.red   { background: var(--red);  box-shadow: var(--glow-r); }
    .prog-fill.yellow{ background: var(--yellow); }

    /* ── INPUTS ── */
    .input-group { margin-bottom: 10px; }
    .input-group label {
      display: block; font-size: 0.65rem;
      color: var(--text-dim); letter-spacing: 1.5px;
      text-transform: uppercase; margin-bottom: 4px;
    }
    input[type="number"], input[type="text"], select {
      width: 100%; background: var(--bg3);
      border: 1px solid var(--border2); color: var(--text);
      padding: 7px 10px; font-family: 'DM Mono', monospace;
      font-size: 0.85rem; border-radius: 2px; outline: none;
    }
    input:focus, select:focus { border-color: var(--cyan); box-shadow: var(--glow-c); }
    select option { background: var(--bg2); }

    /* ── BUTTONS ── */
    .btn {
      padding: 8px 18px; border: none; cursor: pointer;
      font-family: 'Share Tech Mono', monospace;
      font-size: 0.8rem; letter-spacing: 1.5px;
      text-transform: uppercase; border-radius: 2px;
      transition: all 0.15s;
    }
    .btn-cyan {
      background: #00e5ff18; color: var(--cyan);
      border: 1px solid var(--cyan-dim);
    }
    .btn-cyan:hover { background: #00e5ff30; box-shadow: var(--glow-c); }
    .btn-green {
      background: #00ff8818; color: var(--green);
      border: 1px solid var(--green-dim);
    }
    .btn-green:hover { background: #00ff8830; box-shadow: var(--glow-g); }
    .btn-red {
      background: #ff386018; color: var(--red);
      border: 1px solid var(--red-dim);
    }
    .btn-red:hover { background: #ff386030; box-shadow: var(--glow-r); }
    .btn-full { width: 100%; margin-top: 6px; padding: 10px; }

    /* ── MINI CHART ── */
    canvas { display: block; }

    /* ── LOG TERMINAL ── */
    .terminal {
      background: #010609; border: 1px solid var(--border);
      border-radius: 2px; padding: 10px;
      height: 180px; overflow-y: auto;
      font-size: 0.75rem; line-height: 1.7;
    }
    .terminal::-webkit-scrollbar { width: 4px; }
    .terminal::-webkit-scrollbar-track { background: var(--bg); }
    .terminal::-webkit-scrollbar-thumb { background: var(--border2); }
    .log-line { font-family: 'Share Tech Mono', monospace; }
    .log-info  { color: var(--cyan-dim); }
    .log-ok    { color: var(--green); }
    .log-warn  { color: var(--yellow); }
    .log-err   { color: var(--red); }
    .log-ts    { color: var(--text-faint); margin-right: 8px; }

    /* ── SPARKLINE ── */
    .sparkline-wrap { position: relative; height: 60px; margin-top: 8px; }

    /* ── FORMULA BOX ── */
    .formula {
      background: var(--bg3); border-left: 2px solid var(--cyan);
      padding: 8px 12px; margin: 8px 0;
      font-size: 0.75rem; color: var(--cyan-dim);
      font-family: 'Share Tech Mono', monospace;
    }

    /* ── RISK METER ── */
    .risk-arc { text-align: center; padding: 8px 0; }

    /* ── MARKET SCANNER ROWS ── */
    .scan-row {
      display: flex; align-items: center;
      padding: 8px 0; border-bottom: 1px solid var(--text-faint);
      gap: 10px; cursor: pointer;
      transition: background 0.1s;
    }
    .scan-row:hover { background: var(--bg3); padding-left: 4px; }
    .scan-market { flex: 1; font-size: 0.8rem; color: var(--text); }
    .scan-prob { width: 48px; text-align: right; font-family: 'Orbitron', monospace; font-size: 0.85rem; }
    .scan-ev { width: 52px; text-align: right; font-size: 0.8rem; }
    .scan-edge { width: 52px; text-align: right; font-size: 0.75rem; color: var(--text-dim); }

    /* ── POSITION ENTRY ── */
    .kelly-result {
      margin-top: 10px; padding: 10px;
      background: var(--bg3); border: 1px solid var(--border2);
      border-radius: 2px;
    }
    .kelly-val {
      font-family: 'Orbitron', monospace;
      font-size: 2rem; font-weight: 700;
      color: var(--green); text-shadow: var(--glow-g);
    }

    /* ── BACKTEST CHART ── */
    #btChart { width: 100%; height: 200px; }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .grid-3, .grid-4 { grid-template-columns: 1fr 1fr; }
      .grid-2 { grid-template-columns: 1fr; }
      .col-span-2, .col-span-3 { grid-column: span 1; }
    }
    @media (max-width: 480px) {
      .grid-3, .grid-4 { grid-template-columns: 1fr; }
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(6px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .panel.active { animation: fadeIn 0.25s ease; }

    @keyframes blink { 50% { opacity: 0; } }
    .cursor { animation: blink 1s step-end infinite; color: var(--cyan); }

    .ticker-scroll {
      font-size: 0.7rem; color: var(--text-dim);
      font-family: 'Share Tech Mono', monospace;
      white-space: nowrap; overflow: hidden;
      border-top: 1px solid var(--border);
      padding: 4px 0; margin-top: 16px;
    }
    .ticker-inner {
      display: inline-block;
      animation: ticker 30s linear infinite;
    }
    @keyframes ticker {
      from { transform: translateX(100vw); }
      to   { transform: translateX(-100%); }
    }
  </style>
</head>
<body>
<div id="app">

  <!-- HEADER -->
  <header>
    <div class="logo">ALGO<span>TRADE</span> BOT <span class="cursor">█</span></div>
    <div class="header-right">
      <div class="status-dot"></div>
      <div class="clock" id="clock">--:--:--</div>
      <div class="badge badge-green">LIVE</div>
    </div>
  </header>

  <!-- TABS -->
  <div class="tabs">
    <button class="tab active" onclick="switchTab('dashboard')">Dashboard</button>
    <button class="tab" onclick="switchTab('scanner')">Market Scanner</button>
    <button class="tab" onclick="switchTab('position')">Position Sizer</button>
    <button class="tab" onclick="switchTab('backtest')">Backtest</button>
    <button class="tab" onclick="switchTab('risk')">Risk Manager</button>
  </div>

  <!-- ══════════ DASHBOARD ══════════ -->
  <div id="tab-dashboard" class="panel active">
    <div class="grid-4" style="margin-bottom:12px">
      <div class="card">
        <div class="card-title">Portfolio Value</div>
        <div class="stat-val up" id="portfolioVal">$10,247.83</div>
        <div class="stat-label">Total Capital</div>
        <div class="stat-change up" id="portfolioChg">▲ +2.47% today</div>
      </div>
      <div class="card">
        <div class="card-title">Open Positions</div>
        <div class="stat-val neutral" id="openPos">7</div>
        <div class="stat-label">Active Trades</div>
        <div class="stat-change neutral">$1,840 deployed</div>
      </div>
      <div class="card">
        <div class="card-title">Win Rate</div>
        <div class="stat-val up" id="winRate">64.2%</div>
        <div class="stat-label">Last 30 days</div>
        <div class="prog-bar"><div class="prog-fill green" style="width:64.2%"></div></div>
      </div>
      <div class="card">
        <div class="card-title">Sharpe Ratio</div>
        <div class="stat-val up" id="sharpe">2.14</div>
        <div class="stat-label">Annualised</div>
        <div class="stat-change up">▲ Excellent</div>
      </div>
    </div>

    <div class="grid-3" style="margin-bottom:12px">
      <div class="card col-span-2">
        <div class="card-title">Equity Curve</div>
        <canvas id="equityChart" height="120"></canvas>
      </div>
      <div class="card">
        <div class="card-title">P&amp;L Today</div>
        <div class="stat-val up" style="font-size:1.3rem">+$247.83</div>
        <div class="stat-label" style="margin-bottom:10px">Realised</div>
        <div style="display:flex;justify-content:space-between;font-size:0.75rem;margin-bottom:4px">
          <span style="color:var(--text-dim)">Unrealised</span>
          <span class="up">+$112.40</span>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:0.75rem;margin-bottom:4px">
          <span style="color:var(--text-dim)">Fees</span>
          <span class="down">-$18.20</span>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:0.75rem;margin-bottom:4px">
          <span style="color:var(--text-dim)">Net P&L</span>
          <span class="up">+$342.03</span>
        </div>
        <hr style="border-color:var(--border);margin:8px 0">
        <div style="font-size:0.7rem;color:var(--text-dim)">Max Drawdown</div>
        <div style="color:var(--red);font-family:'Orbitron',monospace;font-size:1rem">-4.2%</div>
        <div class="prog-bar"><div class="prog-fill red" style="width:4.2%"></div></div>
      </div>
    </div>

    <div class="grid-2">
      <div class="card">
        <div class="card-title">Recent Trades</div>
        <table class="data-table">
          <thead>
            <tr><th>Market</th><th>Side</th><th>Entry</th><th>Exit</th><th>P&L</th></tr>
          </thead>
          <tbody id="recentTrades"></tbody>
        </table>
      </div>
      <div class="card">
        <div class="card-title">System Log</div>
        <div class="terminal" id="sysLog"></div>
      </div>
    </div>
  </div>

  <!-- ══════════ MARKET SCANNER ══════════ -->
  <div id="tab-scanner" class="panel">
    <div class="grid-3" style="margin-bottom:12px">
      <div class="card col-span-2">
        <div class="card-title">Live Market Scan <span class="badge badge-cyan" style="margin-left:8px">SCANNING</span></div>
        <div style="display:flex;gap:8px;margin-bottom:10px">
          <select id="scanCategory" style="flex:1" onchange="runScan()">
            <option>All Markets</option>
            <option>Politics</option>
            <option>Crypto</option>
            <option>Sports</option>
            <option>Economics</option>
          </select>
          <select id="scanSort" style="flex:1" onchange="runScan()">
            <option>Sort: Best EV</option>
            <option>Sort: Highest Edge</option>
            <option>Sort: Volume</option>
          </select>
          <button class="btn btn-cyan" onclick="runScan()">↻ RESCAN</button>
        </div>
        <div id="scanResults"></div>
      </div>
      <div class="card">
        <div class="card-title">Scanner Stats</div>
        <div style="margin-bottom:12px">
          <div class="stat-label">Markets Scanned</div>
          <div class="stat-val neutral" id="mktCount">247</div>
        </div>
        <div style="margin-bottom:12px">
          <div class="stat-label">Edge Found</div>
          <div class="stat-val up" id="edgeCount">18</div>
        </div>
        <div style="margin-bottom:12px">
          <div class="stat-label">Avg EV</div>
          <div class="stat-val up">+6.3%</div>
        </div>
        <div class="formula">
          EV = (p × b) − (1 − p)<br>
          where p = model prob<br>
          b = market odds − 1
        </div>
        <button class="btn btn-green btn-full" onclick="autoTrade()">⚡ AUTO-TRADE TOP 3</button>
      </div>
    </div>
  </div>

  <!-- ══════════ POSITION SIZER ══════════ -->
  <div id="tab-position" class="panel">
    <div class="grid-2">
      <div class="card">
        <div class="card-title">Kelly Criterion Calculator</div>
        <div class="formula">
          f* = (bp − q) / b<br>
          b = odds − 1 &nbsp; p = win prob &nbsp; q = 1−p
        </div>
        <div class="input-group">
          <label>Your Estimated Win Probability (%)</label>
          <input type="number" id="kWinProb" value="60" min="1" max="99" oninput="calcKelly()" />
        </div>
        <div class="input-group">
          <label>Market Odds (decimal)</label>
          <input type="number" id="kOdds" value="2.10" step="0.01" min="1.01" oninput="calcKelly()" />
        </div>
        <div class="input-group">
          <label>Bankroll ($)</label>
          <input type="number" id="kBankroll" value="10000" oninput="calcKelly()" />
        </div>
        <div class="input-group">
          <label>Kelly Fraction (0.25 = quarter Kelly)</label>
          <input type="number" id="kFraction" value="0.25" step="0.05" min="0.05" max="1" oninput="calcKelly()" />
        </div>

        <div class="kelly-result">
          <div style="font-size:0.7rem;color:var(--text-dim);letter-spacing:1px;margin-bottom:4px">RECOMMENDED BET SIZE</div>
          <div class="kelly-val" id="kellyAmt">$0.00</div>
          <div style="font-size:0.75rem;color:var(--text-dim);margin-top:4px" id="kellyPct">0.00% of bankroll</div>
          <div style="margin-top:8px;font-size:0.75rem" id="kellyEV"></div>
        </div>
        <button class="btn btn-green btn-full" onclick="placeTrade()">▶ PLACE TRADE</button>
      </div>

      <div class="card">
        <div class="card-title">Risk Metrics</div>
        <div style="margin-bottom:12px">
          <div class="stat-label">Expected Value</div>
          <div class="stat-val up" id="evDisplay">--</div>
        </div>
        <div style="margin-bottom:12px">
          <div class="stat-label">Value at Risk (95%)</div>
          <div class="stat-val down" id="varDisplay">--</div>
        </div>
        <div style="margin-bottom:12px">
          <div class="stat-label">Brier Score (accuracy)</div>
          <div class="stat-val neutral" id="brierDisplay">--</div>
        </div>
        <hr style="border-color:var(--border);margin:12px 0">
        <div class="card-title">Active Positions</div>
        <table class="data-table">
          <thead>
            <tr><th>Market</th><th>Stake</th><th>P</th><th>EV</th><th></th></tr>
          </thead>
          <tbody id="positionsTable"></tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ══════════ BACKTEST ══════════ -->
  <div id="tab-backtest" class="panel">
    <div class="grid-3" style="margin-bottom:12px">
      <div class="card">
        <div class="card-title">Strategy Config</div>
        <div class="input-group">
          <label>Strategy</label>
          <select id="btStrategy" onchange="runBacktest()">
            <option>Kelly Full</option>
            <option>Quarter Kelly</option>
            <option>Fixed 2%</option>
            <option>Fixed 5%</option>
            <option>Half Kelly</option>
          </select>
        </div>
        <div class="input-group">
          <label>Starting Capital ($)</label>
          <input type="number" id="btCapital" value="10000" oninput="runBacktest()" />
        </div>
        <div class="input-group">
          <label>Min Edge Required (%)</label>
          <input type="number" id="btEdge" value="5" oninput="runBacktest()" />
        </div>
        <div class="input-group">
          <label>Simulated Trades</label>
          <input type="number" id="btTrades" value="100" min="10" max="500" oninput="runBacktest()" />
        </div>
        <div class="input-group">
          <label>Win Rate (%)</label>
          <input type="number" id="btWinRate" value="58" min="1" max="99" oninput="runBacktest()" />
        </div>
        <button class="btn btn-cyan btn-full" onclick="runBacktest()">▶ RUN SIMULATION</button>
      </div>

      <div class="card col-span-2">
        <div class="card-title">Equity Simulation</div>
        <canvas id="btChart"></canvas>
