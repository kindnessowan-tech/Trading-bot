function drawEquityChart() {
  const canvas = document.getElementById('equityChart');
  if (!canvas) return;
  canvas.width  = canvas.offsetWidth || 600;
  canvas.height = 120;
  const ctx = canvas.getContext('2d');
  const data = Array.from({length: 60}, (_, i) =>
    9000 + Math.sin(i * 0.3) * 400 + i * 22 + Math.random() * 150);

  ctx.clearRect(0, 0, canvas.width, canvas.height);
  const min = Math.min(...data), max = Math.max(...data);
  const range = max - min || 1;
  const w = canvas.width, h = canvas.height;
  const px = i => (i / (data.length - 1)) * w;
  const py = v => h - ((v - min) / range) * (h - 16) - 4;

  // gradient fill
  const grad = ctx.createLinearGradient(0, 0, 0, h);
  grad.addColorStop(0, '#00ff8840');
  grad.addColorStop(1, '#00ff8800');
  ctx.beginPath();
  ctx.moveTo(px(0), py(data[0]));
  data.forEach((v, i) => ctx.lineTo(px(i), py(v)));
  ctx.lineTo(w, h); ctx.lineTo(0, h); ctx.closePath();
  ctx.fillStyle = grad; ctx.fill();

  // line
  ctx.beginPath();
  ctx.moveTo(px(0), py(data[0]));
  data.forEach((v, i) => ctx.lineTo(px(i), py(v)));
  ctx.strokeStyle = '#00ff88'; ctx.lineWidth = 1.5;
  ctx.shadowColor = '#00ff88'; ctx.shadowBlur = 6;
  ctx.stroke(); ctx.shadowBlur = 0;
}

function drawBacktestChart(equity) {
  const canvas = document.getElementById('btChart');
  if (!canvas) return;
  canvas.width  = canvas.offsetWidth || 600;
  canvas.height = 200;
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  const min = Math.min(...equity), max = Math.max(...equity);
  const range = max - min || 1;
  const w = canvas.width, h = canvas.height;
  const px = i => (i / (equity.length - 1)) * w;
  const py = v => h - ((v - min) / range) * (h - 20) - 8;

  // grid lines
  ctx.strokeStyle = '#0f2a3f'; ctx.lineWidth = 1;
  for (let i = 0; i <= 4; i++) {
    const y = (i / 4) * h;
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(w, y); ctx.stroke();
  }

  const isProfit = equity[equity.length - 1] >= equity[0];
  const lineColor = isProfit ? '#00ff88' : '#ff3860';
  const fillColor = isProfit ? '#00ff8825' : '#ff386020';

  const grad = ctx.createLinearGradient(0, 0, 0, h);
  grad.addColorStop(0, isProfit ? '#00ff8840' : '#ff386040');
  grad.addColorStop(1, 'transparent');
  ctx.beginPath();
  ctx.moveTo(px(0), py(equity[0]));
  equity.forEach((v, i) => ctx.lineTo(px(i), py(v)));
  ctx.lineTo(w, h); ctx.lineTo(0, h); ctx.closePath();
  ctx.fillStyle = grad; ctx.fill();

  ctx.beginPath();
  ctx.moveTo(px(0), py(equity[0]));
  equity.forEach((v, i) => ctx.lineTo(px(i), py(v)));
  ctx.strokeStyle = lineColor; ctx.lineWidth = 2;
  ctx.shadowColor = lineColor; ctx.shadowBlur = 8;
  ctx.stroke(); ctx.shadowBlur = 0;

  // labels
  ctx.fillStyle = '#4a6a7a'; ctx.font = '10px DM Mono, monospace';
  ctx.fillText('$' + min.toFixed(0), 4, h - 4);
  ctx.fillText('$' + max.toFixed(0), 4, 14);
}

function drawRiskChart() {
  const canvas = document.getElementById('riskChart');
  if (!canvas) return;
  canvas.width  = canvas.offsetWidth || 300;
  canvas.height = 160;
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0, 0, canvas.width, canvas.height);

  const segments = [
    { label: 'Politics', pct: 0.32, color: '#00e5ff' },
    { label: 'Crypto',   pct: 0.28, color: '#00ff88' },
    { label: 'Macro',    pct: 0.22, color: '#ffd600' },
    { label: 'Sports',   pct: 0.18, color: '#ff3860' },
  ];

  const cx = canvas.width / 2, cy = canvas.height / 2, r = 60;
  let angle = -Math.PI / 2;
  segments.forEach(seg => {
    const slice = seg.pct * 2 * Math.PI;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, r, angle, angle + slice);
    ctx.closePath();
    ctx.fillStyle = seg.color + '80';
    ctx.strokeStyle = seg.color;
    ctx.lineWidth = 1.5;
    ctx.fill(); ctx.stroke();

    // label
    const midAngle = angle + slice / 2;
    const lx = cx + (r + 18) * Math.cos(midAngle);
    const ly = cy + (r + 18) * Math.sin(midAngle);
    ctx.fillStyle = seg.color;
    ctx.font = '9px Share Tech Mono, monospace';
    ctx.textAlign = 'center';
    ctx.fillText(seg.label, lx, ly);

    angle += slice;
  });

  // center
  ctx.beginPath(); ctx.arc(cx, cy, 28, 0, 2*Math.PI);
  ctx.fillStyle = '#060d14'; ctx.fill();
  ctx.fillStyle = '#c8dde8'; ctx.font = '9px Orbitron, monospace';
  ctx.textAlign = 'center';
  ctx.fillText('RISK', cx, cy - 3);
  ctx.fillText('MIX', cx, cy + 9);
}

